{
    "name": "roam-vim-navigation",
    "version": "0.1.0",
    "description": "Standalone Vim-like navigation and editing extension for Roam Research",
    "scripts": {
        "build": "node ./scripts/build-roam-vim-plugin.mjs",
        "build:vim-plugin": "node ./scripts/build-roam-vim-plugin.mjs",
        "clean": "rm -rf ./dist ./extension.js",
        "clean:all": "rm -rf ./dist ./extension.js && rm -rf ./coverage && rm -rf ./node_modules",
        "prepare": "husky",
        "test": "jest",
        "typecheck": "tsc --noEmit",
        "test:coverage": "jest --collect-coverage",
        "prettify": "prettier --write \"{src,tests,scripts}/**/*.{ts,js,mjs}\" \"*.{cjs,json,md}\" \".github/workflows/*.yml\"",
        "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.mjs\" \"*.{js,cjs}\""
    },
    "license": "MIT",
    "dependencies": {
        "immutable": "^5.1.5",
        "lodash": "^4.18.1",
        "tinykeys": "^3.0.0",
        "tslib": "^2.8.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/jest": "^30.0.0",
        "@types/lodash": "^4.17.24",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "esbuild": "^0.28.0",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.5.0",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "jest-environment-jsdom": "^30.3.0",
        "jest-extended": "^7.0.0",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "ts-jest": "^29.4.9",
        "typescript": "^6.0.3"
    }
}
